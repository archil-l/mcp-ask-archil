{
  "name": "mcp-ask-archil",
  "version": "1.0.0",
  "description": "MCP server with tools and knowledgebase for ask-archil-io",
  "author": "Archil Lelashvili <archil-l@outlook.com>",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build:apps && node esbuild.config.mjs && tsc -p cdk/tsconfig.json && npx cdk synth",
    "build:cdk": "tsc -p cdk/tsconfig.json",
    "build:apps": "npm run build:app:get-resume",
    "build:app:get-resume": "cd src/apps/get-resume && cross-env INPUT=get-resume-app.html vite build",
    "watch:app:get-resume": "cd src/apps/get-resume && cross-env INPUT=get-resume-app.html vite build --watch",
    "mcp": "npm-run-all --parallel mcp:proxy mcp:inspector",
    "mcp:proxy": "AWS_PROFILE=agent node --env-file=.env --import=tsx scripts/mcp-proxy.ts",
    "mcp:inspector": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector",
    "dev": "cross-env NODE_ENV=development concurrently \"npm run watch:app:get-resume\" \"npm run mcp:proxy\"",
    "deploy": "npx cdk deploy mcp-server-archil-io-prod --profile agent"
  },
  "dependencies": {
    "@aws-sdk/client-route-53": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-sts": "^3.1014.0",
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.6.0",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.7.6",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-provider-node": "^3.972.23",
    "@smithy/protocol-http": "^5.3.12",
    "@smithy/signature-v4": "^5.3.12",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-cdk": "2.1106.0",
    "aws-cdk-lib": "^2.241.0",
    "concurrently": "^9.2.1",
    "constructs": "^10.4.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
