    "@aws-sdk/client-route-53": "^3.893.0",
    "@aws-sdk/client-sts": "^3.893.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "serverless-http": "^4.0.0",
    "source-map-support": "^0.5.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-provider-node": "^3.972.23",
    "@smithy/protocol-http": "^5.3.12",
    "@smithy/signature-v4": "^5.3.12",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1106.0",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.27.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
