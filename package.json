  "author": "Archil Lelashvili <archil-l@outlook.com>",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && node esbuild.config.mjs",
    "build:cdk": "tsc -p cdk/tsconfig.json",
    "deploy": "npm run build && npm run build:cdk && npx cdk deploy"
  },
